class car:
    def hasPart(self):
        haspart = ["Engine","Wheel","Radiator","Brake Pad", "Brake Caliper",
                   "Steering Wheel", "Suspension","Fuel Tank","Fuel Pump",
                   "Spark Plug", "Air Filter","Oil Filter", "Windshield",
                   "Windshield Wiper","Headlight", "Taillight", "Side Mirror",
                   "Rear-view Mirror", "Seat Belt", "Dashboard"]
        for i in haspart:
            print("::) ",i)

    def doesPart(self):
        print("Forward Moving")
        print("Backward Moving")

class KIA(car):
    def additionalHasPart(self):
        p = ["Kia OEM LED Headlight Assembly","Housing and Main Shell",
             "Projector Lens and Reflector","Headlight Halogen/LED Bulb",
             "Daytime Running Light (DRL) Module"]
        for i in p:
            print("::) ",i)

    def additionalDoesPart(self):
        print("ADAS -> Advanced Driver Assistance Systems")

k = KIA()
k.hasPart()
k.doesPart()
k.additionalHasPart()
k.additionalDoesPart()

